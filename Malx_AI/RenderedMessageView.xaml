<UserControl x:Class="Malx_AI.RenderedMessageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             HorizontalAlignment="Stretch"
             HorizontalContentAlignment="Stretch"
             ClipToBounds="True"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid ClipToBounds="True">
        <TextBlock x:Name="PlainTextBlock"
                   Text="{Binding PlainText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Top"
                   Foreground="{DynamicResource NotebookTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="14"/>
        <Image x:Name="RenderedImage"
               Visibility="Collapsed"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Stretch="Uniform"
               SnapsToDevicePixels="True"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderOptions.EdgeMode="Unspecified"/>
        <Canvas x:Name="BrowserHost"
                Width="0"
                Height="0"
                ClipToBounds="True"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <wv2:WebView2 x:Name="Browser"
                          Canvas.Left="0"
                          Canvas.Top="0"
                          DefaultBackgroundColor="#211F1D"
                          Width="1"
                          Height="24"
                          Visibility="Collapsed"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Focusable="False"
                          IsHitTestVisible="False"/>
        </Canvas>
    </Grid>
</UserControl>

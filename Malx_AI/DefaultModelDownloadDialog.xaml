<Window x:Class="Malx_AI.DefaultModelDownloadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download default model"
        Width="520" Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#171615"
        Foreground="#EDE8E3">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="#211F1D"/>
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="#4A4641"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Margin="20" Padding="22" Background="#211F1D" BorderBrush="#302D2A" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Axiom Qwen3-4B" FontSize="21" FontWeight="SemiBold" Foreground="#EDE8E3"/>
            <TextBlock Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#B0A89F"
                       Text="Download the recommended 2.5 GB GGUF model from Hugging Face. Axiom verifies its SHA-256 checksum, stores it in your local app data, and imports it automatically."/>

            <ProgressBar x:Name="DownloadProgressBar" Grid.Row="2" Height="12" Margin="0,24,0,0"
                         Minimum="0" Maximum="100" Value="0" Foreground="#B8924A" Background="#302D2A"/>
            <TextBlock x:Name="DownloadProgressText" Grid.Row="3" Margin="0,9,0,0" Foreground="#B0A89F"
                       Text="Ready to download."/>
            <TextBlock x:Name="DownloadErrorText" Grid.Row="4" Margin="0,12,0,0" TextWrapping="Wrap"
                       Foreground="#C96A5B" Visibility="Collapsed"/>

            <StackPanel Grid.Row="5" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelDownloadButton" Content="Not now" Click="CancelDownloadButton_Click" Margin="0,0,10,0"/>
                <Button x:Name="StartDownloadButton" Content="Download default model" Click="StartDownloadButton_Click"
                        MinWidth="190" Background="#B8924A" BorderBrush="#B8924A" Foreground="#171615" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

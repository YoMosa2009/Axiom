<UserControl x:Class="Malx_AI.WorkplaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Malx_AI"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{StaticResource NotebookBackgroundBrush}" Foreground="{StaticResource NotebookTextBrush}"
             UseLayoutRounding="True" SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="WorkplaceTokenMeterProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="#302D2A"/>
            <Setter Property="Foreground" Value="#5FAF7D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="CouncilSidebarColumn" Width="300" MinWidth="270" MaxWidth="380"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="CanvasColumn" Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LEFT SIDEBAR — Council + Knowledge Base     -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource NotebookSurfaceBrush}" BorderThickness="0,0,1,0" BorderBrush="{StaticResource NotebookBorderBrush}">
            <ScrollViewer x:Name="CouncilSidebarScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0" PreviewMouseWheel="SidebarScrollViewer_PreviewMouseWheel">
                <StackPanel Margin="16,16,16,20">
                    <TextBlock Text="Workplace Council" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="Configure up to three relay models" FontSize="11" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,4,0,0"/>

                    <!-- Architect -->
                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Architect" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ArchitectModelBlock" Text="No model selected" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,8"/>
                            <ComboBox x:Name="ArchitectFormatCombo" SelectedIndex="0" Height="28" Margin="0,0,0,8">
                                <ComboBoxItem Content="ChatML"/>
                                <ComboBoxItem Content="Llama 3"/>
                                <ComboBoxItem Content="Alpaca"/>
                            </ComboBox>
                            <Button x:Name="LoadArchitectModelButton" Content="Load Architect Model" Click="LoadArchitectModel_Click" Height="32" Style="{StaticResource SubtleButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Builder -->
                    <Border x:Name="RoleContextControlsCard" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Builder" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="BuilderModelBlock" Text="No model selected" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,8"/>
                            <ComboBox x:Name="BuilderFormatCombo" SelectedIndex="0" Height="28" Margin="0,0,0,8">
                                <ComboBoxItem Content="ChatML"/>
                                <ComboBoxItem Content="Llama 3"/>
                                <ComboBoxItem Content="Alpaca"/>
                            </ComboBox>
                            <Button x:Name="LoadBuilderModelButton" Content="Load Builder Model" Click="LoadBuilderModel_Click" Height="32" Style="{StaticResource SubtleButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Critic -->
                    <Border x:Name="ManualRoleContextControlsCard" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Critic" FontSize="11" FontWeight="SemiBold"/>
                                <Border Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="6,1" Margin="6,0,0,0" DockPanel.Dock="Right">
                                    <TextBlock x:Name="CriticSensitivityBadgeText" Text="Standard" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                </Border>
                            </DockPanel>
                            <TextBlock x:Name="CriticModelBlock" Text="No model selected" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,8"/>
                            <ComboBox x:Name="CriticFormatCombo" SelectedIndex="0" Height="28" Margin="0,0,0,8">
                                <ComboBoxItem Content="ChatML"/>
                                <ComboBoxItem Content="Llama 3"/>
                                <ComboBoxItem Content="Alpaca"/>
                            </ComboBox>
                            <Button x:Name="LoadCriticModelButton" Content="Load Critic Model" Click="LoadCriticModel_Click" Height="32" Style="{StaticResource SubtleButtonStyle}"/>
                            <TextBlock Text="Critic Sensitivity" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,8,0,4"/>
                            <ComboBox x:Name="CriticSensitivityCombo" SelectionChanged="CriticSensitivityCombo_SelectionChanged" Height="26" SelectedIndex="0">
                                <ComboBoxItem Content="Standard"/>
                                <ComboBoxItem Content="Strict"/>
                                <ComboBoxItem Content="Critical Only"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Role Context Controls" FontSize="11" FontWeight="SemiBold"/>
                            <CheckBox x:Name="AutoOptimizeContextToggle" Content="Auto optimize (model-aware)" IsChecked="True" Margin="0,8,0,8" Checked="AutoOptimizeContextToggle_Changed" Unchecked="AutoOptimizeContextToggle_Changed"/>

                            <!-- Cloud mode info panel (visible only when cloud council is active) -->
                            <TextBlock x:Name="CloudContextInfoBlock" Visibility="Collapsed" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>

                            <!-- Local slider controls (hidden in cloud mode) -->
                            <StackPanel x:Name="ContextSlidersPanel">
                                <TextBlock Text="Global Context" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                <Slider x:Name="GlobalContextSlider" Minimum="2048" Maximum="32768" TickFrequency="512" IsSnapToTickEnabled="True" Value="8192" ValueChanged="GlobalContextSlider_ValueChanged"/>
                                <TextBlock x:Name="GlobalContextValueText" Text="8192 tokens" FontSize="10" Foreground="{StaticResource PrimaryAccentBrush}" Margin="0,2,0,8"/>

                                <TextBlock Text="Architect Context" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                <Slider x:Name="ArchitectContextSlider" Minimum="2048" Maximum="32768" TickFrequency="512" IsSnapToTickEnabled="True" Value="6144" ValueChanged="RoleContextSlider_ValueChanged"/>
                                <TextBlock x:Name="ArchitectContextValueText" Text="6144 tokens" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,6"/>

                                <TextBlock Text="Builder Context" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                <Slider x:Name="BuilderContextSlider" Minimum="2048" Maximum="32768" TickFrequency="512" IsSnapToTickEnabled="True" Value="8192" ValueChanged="RoleContextSlider_ValueChanged"/>
                                <TextBlock x:Name="BuilderContextValueText" Text="8192 tokens" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,6"/>

                                <TextBlock Text="Critic Context" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                <Slider x:Name="CriticContextSlider" Minimum="2048" Maximum="32768" TickFrequency="512" IsSnapToTickEnabled="True" Value="4096" ValueChanged="RoleContextSlider_ValueChanged"/>
                                <TextBlock x:Name="CriticContextValueText" Text="4096 tokens" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Rectangle Height="1" Fill="{StaticResource NotebookBorderBrush}" Margin="0,16,0,16"/>

                    <!-- Connected Workspace -->
                    <TextBlock Text="Connected Workspace" FontSize="12" FontWeight="SemiBold"/>
                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Codebase Edit Access" FontSize="11" FontWeight="SemiBold"/>
                                <Border x:Name="CodebaseAccessModeBadge" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="6,1" Margin="6,0,0,0" DockPanel.Dock="Right">
                                    <TextBlock x:Name="CodebaseAccessModeText" Text="Off" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                </Border>
                            </DockPanel>
                            <TextBlock x:Name="ConnectedWorkspaceStatusBlock" Text="Step 1: enable access. This locks the chat to the current local/cloud mode." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                            <Button x:Name="CodebaseEditAccessButton" Content="1. Enable for this chat" Click="CodebaseEditAccessButton_Click" Height="32" Style="{StaticResource PremiumButtonStyle}"/>
                            <TextBlock x:Name="ConnectedWorkspaceConnectHintBlock" Text="Step 2: connect code from your computer or clone a repo." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,10,0,6" TextWrapping="Wrap"/>
                            <Button x:Name="ConnectWorkspaceFolderButton" Content="Open Local Folder" Click="ConnectWorkspaceFolderButton_Click" Height="30" Style="{StaticResource SubtleButtonStyle}" IsEnabled="False"/>
                            <Button x:Name="ConnectWorkspaceFilesButton" Content="Pick Individual Files" Click="ConnectWorkspaceFilesButton_Click" Height="30" Margin="0,6,0,0" Style="{StaticResource SubtleButtonStyle}" IsEnabled="False"/>
                            <Button x:Name="ConnectWorkspaceRepositoryButton" Content="Clone GitHub/Repo" Click="ConnectWorkspaceRepositoryButton_Click" Height="30" Margin="0,6,0,0" Style="{StaticResource SubtleButtonStyle}" IsEnabled="False"/>
                            <Button x:Name="CloneWorkspaceRepositoryButton" Content="Clone Repo to Folder" Click="CloneWorkspaceRepositoryButton_Click" Height="30" Margin="0,6,0,0" Style="{StaticResource SubtleButtonStyle}" IsEnabled="False"/>
                            <TextBlock x:Name="ConnectedWorkspaceDetailBlock" Text="No code connected yet." FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="CodebaseReviewHintBlock" Text="Step 3: ask for a change. Proposed edits appear in Project Canvas for review." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,10,0,6" TextWrapping="Wrap"/>
                            <CheckBox x:Name="CodebaseAutoApplyToggle" Content="Auto apply valid patches" Margin="0,0,0,4" Checked="CodebaseAutoApplyToggle_Changed" Unchecked="CodebaseAutoApplyToggle_Changed" IsEnabled="False" ToolTip="When enabled, valid codebase patches are applied automatically after Builder produces them."/>
                            <TextBlock x:Name="CodebaseAutoApplyHintBlock" Text="Manual mode: review patches before writing files." FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Button x:Name="UndoCodebaseChangesSidebarButton" Content="Undo Last Apply" Click="UndoCodebaseChanges_Click" Height="28" Margin="0,0,0,8" Style="{StaticResource SubtleButtonStyle}" Visibility="Collapsed" IsEnabled="False"/>
                            <UniformGrid x:Name="CodebaseReviewActionGrid" Columns="2" Margin="0,0,0,0">
                                <Button x:Name="AcceptCodebaseChangesSidebarButton" Content="Accept Changes" Click="AcceptCodebaseChanges_Click" Height="28" Margin="0,0,4,0" Style="{StaticResource SubtleButtonStyle}" IsEnabled="False"/>
                                <Button x:Name="RejectCodebaseChangesSidebarButton" Content="Reject" Click="RejectCodebaseChanges_Click" Height="28" Margin="4,0,0,0" Style="{StaticResource SubtleButtonStyle}" IsEnabled="False"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Rectangle Height="1" Fill="{StaticResource NotebookBorderBrush}" Margin="0,16,0,16"/>

                    <!-- Knowledge Base -->
                    <TextBlock Text="Project Knowledge Base" FontSize="12" FontWeight="SemiBold"/>
                    <Border x:Name="DropZone" Background="{StaticResource NotebookBackgroundBrush}" BorderThickness="1" BorderBrush="{StaticResource NotebookBorderBrush}"
                            CornerRadius="12" Padding="16" Margin="0,12,0,12" AllowDrop="True"
                            Drop="DropZone_Drop" DragOver="DropZone_DragOver">
                        <StackPanel>
                            <TextBlock Text="Drop PDF/TXT files here" FontSize="11" Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="or use + Add Document" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Content="+ Add Document" Click="BrowseFiles_Click" Height="34" Style="{StaticResource PremiumButtonStyle}"/>

                    <TextBlock Text="Loaded Documents" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" FontWeight="SemiBold" Margin="0,16,0,6"/>
                    <ListBox x:Name="DocumentListBox" Background="Transparent" BorderThickness="0" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource NotebookBackgroundBrush}" CornerRadius="12" Padding="10" Margin="0,4" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}"/>
                                        <TextBlock Text="{Binding Info}" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Clear Documents" Click="ClearDocuments_Click" Height="30" Margin="0,8,0,0" Style="{StaticResource SubtleButtonStyle}"/>

                    <Rectangle Height="1" Fill="{StaticResource NotebookBorderBrush}" Margin="0,16,0,16"/>

                    <!-- Session Memory -->
                    <TextBlock Text="Council Session Memory" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SessionMemoryStatusBlock" Text="No prior run stored." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,4,0,8"/>
                    <Button Content="Clear Session Memory" Click="ClearSessionMemory_Click" Height="30" Style="{StaticResource SubtleButtonStyle}"/>

                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Session Hippocampus" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}"/>
                            <TextBlock x:Name="HippocampusLineOneBlock" Text="No prior knowledge loaded." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="HippocampusLineTwoBlock" Text="" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="StudySessionButton" Content="Start Study Session" Click="StudySessionButton_Click" Height="34" Margin="0,10,0,0" Style="{StaticResource PremiumButtonStyle}" FontWeight="SemiBold"/>

                    <Rectangle Height="1" Fill="{StaticResource NotebookBorderBrush}" Margin="0,16,0,16"/>

                    <Expander Header="Task History" IsExpanded="False" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                                <Button Content="Clear History" Click="ClearTaskHistory_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10" Margin="0,0,6,0"/>
                                <Button Content="Compare Selected" Click="CompareTaskHistory_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10"/>
                            </StackPanel>
                            <ListBox x:Name="TaskHistoryListBox" Height="150" SelectionMode="Extended" SelectionChanged="TaskHistoryListBox_SelectionChanged"/>
                            <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,8,0,0">
                                <TextBlock x:Name="TaskHistoryDetailBlock" Text="Select a task history entry to view details." TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Replay" Click="ReplayTaskHistory_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10" Margin="0,0,6,0"/>
                                <Button Content="Compare" Click="CompareTaskHistory_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Performance Log" IsExpanded="False" Margin="0,12,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="PerformanceAggregateBlock" Text="No runs logged yet." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap"/>
                            <Button Content="Export Log" Click="ExportPerformanceLog_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10" Margin="0,8,0,8"/>
                            <ListBox x:Name="PerformanceLogListBox" Height="130" SelectionChanged="PerformanceLogListBox_SelectionChanged"/>
                            <TextBlock x:Name="PerformanceLogDetailBlock" Text="" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Workspace Templates" IsExpanded="False" Margin="0,12,0,0" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                                <Button Content="Create New Template" Click="CreateWorkspaceTemplate_Click" Style="{StaticResource PremiumButtonStyle}" Padding="8,2" FontSize="10" Margin="0,0,6,0"/>
                                <Button Content="Delete" Click="DeleteWorkspaceTemplate_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10"/>
                            </StackPanel>
                            <ListBox x:Name="WorkspaceTemplateListBox" Height="120" SelectionChanged="WorkspaceTemplateListBox_SelectionChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Load" Click="LoadWorkspaceTemplate_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10" Margin="0,0,6,0"/>
                                <Button Content="Edit" Click="EditWorkspaceTemplate_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,2" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Rectangle Height="1" Fill="{StaticResource NotebookBorderBrush}" Margin="0,16,0,16" Visibility="Collapsed"/>

                    <!-- Semantic Memory -->
                    <TextBlock Text="Semantic Project Memory" FontSize="12" FontWeight="SemiBold" Visibility="Collapsed"/>
                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,12,0,0" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160">
                            <ItemsControl x:Name="ConceptCloudItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayLabel}" Tag="{Binding Name}" Click="ConceptTag_Click"
                                                Margin="4" Padding="10,4" FontSize="10" Foreground="{StaticResource NotebookTextBrush}"
                                                Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1"
                                                Style="{StaticResource SubtleButtonStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- CENTER — Header + Chat + Input              -->
        <!-- ═══════════════════════════════════════════ -->
        <DockPanel Grid.Column="1" Background="{StaticResource NotebookBackgroundBrush}">
            <!-- Header bar -->
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,0,0,1" Padding="24,14" Background="{StaticResource NotebookSurfaceBrush}">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="Axiom Workplace" FontSize="18" FontWeight="SemiBold"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="ContextInfoBlock" Text="Context: Ready" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                            <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                            <TextBlock x:Name="HardwareInfoBlock" Text="Adaptive mode" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                            <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                            <TextBlock x:Name="RelayStatusBlock" Text="Relay: Idle" FontSize="10" Foreground="{StaticResource PrimaryAccentBrush}"/>
                            <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                            <Border x:Name="TaskTypeBadge" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6,2" Margin="0,0,8,0">
                                <TextBlock x:Name="TaskTypeBadgeText" Text="General Task" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                            </Border>
                            <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                            <TextBlock x:Name="MemoryFocusBlock" Text="Memory: None" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                            <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                            <TextBlock x:Name="ContextPressureBlock" Text="Context pressure: --" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                            <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                            <TextBlock x:Name="PipelineProgressBlock" Text="" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border x:Name="WorkplaceErrorNotificationBar" DockPanel.Dock="Top" Visibility="Collapsed" Padding="24,8" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="WorkplaceErrorNotificationText" Foreground="{StaticResource PrimaryAccentBrush}" FontSize="11" FontFamily="Segoe UI"/>
            </Border>

            <!-- Run confidence banner. Previously lived at the bottom of the left sidebar where
                 DockPanel.Dock had no effect inside the StackPanel and the result was never seen. -->
            <Border x:Name="CouncilConfidenceBanner" DockPanel.Dock="Top" Visibility="Collapsed" Padding="24,8" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock x:Name="CouncilConfidenceText" Text="Confidence: Moderate" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DarkSecondaryBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="RefineButton" DockPanel.Dock="Right" Content="Refine" Click="RefineButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="10,2" FontSize="10" Margin="8,0,0,0" Visibility="Collapsed" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <Border x:Name="StudySessionNotificationBar" DockPanel.Dock="Top" Visibility="Collapsed" Padding="20,12" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock x:Name="StudySessionStatusText" Text="Study Session in progress..." FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccentBrush}"/>
                    <TextBlock x:Name="StudySessionDetailText" Text="AI models are processing loaded documents. Chat will be restored after completion." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,4,0,0"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="StudySessionProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="StudySessionProgressLabel" Grid.Column="1" Text="0%" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Phase:" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                        <TextBlock x:Name="StudySessionPhaseText" Text="Idle" FontSize="10" Foreground="{StaticResource NotebookTextBrush}" Margin="4,0,0,0"/>
                        <TextBlock Text="  •  " FontSize="10" Foreground="{StaticResource NotebookBorderBrush}"/>
                        <TextBlock Text="Entries:" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                        <TextBlock x:Name="StudySessionEntryCountText" Text="0" FontSize="10" Foreground="{StaticResource NotebookTextBrush}" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Input bar -->
            <Border x:Name="InputAreaContainer" DockPanel.Dock="Bottom" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,1,0,0" Padding="24,12" Background="{StaticResource NotebookSurfaceBrush}">
                <StackPanel>
                    <Border x:Name="RefinementModeBanner" Visibility="Collapsed" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource PrimaryAccentBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                        <TextBlock Text="Refinement Mode" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource PrimaryAccentBrush}" TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="StageActionsPanel" Grid.Row="0" Grid.Column="0" MinWidth="340" MaxWidth="460" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="0"/>
                                </Grid.RowDefinitions>
                                <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,4">
                                    <Border x:Name="ArchitectStageIndicator" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="7,2" Margin="0,0,5,0">
                                        <TextBlock x:Name="ArchitectStageText" Text="Architect · Idle" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                    </Border>
                                    <Border x:Name="BuilderStageIndicator" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="7,2" Margin="0,0,5,0">
                                        <Grid>
                                            <TextBlock x:Name="BuilderStageText" Text="Builder · Idle" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                            <local:ShimmerTextBlock x:Name="BuilderGenerationStatusText"
                                                                    Text="Builder generating"
                                                                    Width="104"
                                                                    FontSize="10"
                                                                    FontWeight="SemiBold"
                                                                    BaseColor="#71717A"
                                                                    HighlightColor="#7DDFA2"
                                                                    ShimmerDurationSeconds="2"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <Border x:Name="CriticStageIndicator" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="7,2">
                                        <TextBlock x:Name="CriticStageText" Text="Critic · Idle" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                    </Border>
                                </UniformGrid>
                                <UniformGrid Grid.Row="1" Columns="4" Visibility="Collapsed">
                                    <Button Click="RerunBuilder_Click" Margin="0,0,5,0" Padding="6,2" FontSize="10" Style="{StaticResource SubtleButtonStyle}" ToolTip="Re-run Builder">
                                        <TextBlock Text="↻ Builder" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button Click="RerunCritic_Click" Margin="0,0,5,0" Padding="6,2" FontSize="10" Style="{StaticResource SubtleButtonStyle}" ToolTip="Re-run Critic">
                                        <TextBlock Text="↻ Critic" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button Click="RerunSandbox_Click" Margin="0,0,5,0" Padding="6,2" FontSize="10" Style="{StaticResource SubtleButtonStyle}" ToolTip="Re-run Sandbox">
                                        <TextBlock Text="↻ Sandbox" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button Click="ExportRunArtifacts_Click" Padding="6,2" FontSize="10" Style="{StaticResource SubtleButtonStyle}" ToolTip="Export Run">
                                        <TextBlock Text="Export" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                    </Button>
                                </UniformGrid>
                            </Grid>
                            <Border x:Name="WorkplaceTokenUsagePanel"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="14,0,0,0"
                                    Padding="14,1,0,1"
                                    VerticalAlignment="Center"
                                    BorderBrush="{StaticResource NotebookBorderBrush}"
                                    BorderThickness="1,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="104" Margin="0,0,12,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="4"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="Architect" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                            <TextBlock x:Name="ArchitectTokenUsageLabel" Text="0 / 0" FontSize="10" HorizontalAlignment="Right" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                        </DockPanel>
                                        <ProgressBar x:Name="ArchitectTokenUsageProgressBar" Grid.Row="1" Minimum="0" Maximum="100" Value="0" Style="{StaticResource WorkplaceTokenMeterProgressBarStyle}"/>
                                    </Grid>
                                    <Grid Width="104" Margin="0,0,12,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="4"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="Builder" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                            <TextBlock x:Name="BuilderTokenUsageLabel" Text="0 / 0" FontSize="10" HorizontalAlignment="Right" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                        </DockPanel>
                                        <ProgressBar x:Name="BuilderTokenUsageProgressBar" Grid.Row="1" Minimum="0" Maximum="100" Value="0" Style="{StaticResource WorkplaceTokenMeterProgressBarStyle}"/>
                                    </Grid>
                                    <Grid Width="104">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="4"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="Critic" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                            <TextBlock x:Name="CriticTokenUsageLabel" Text="0 / 0" FontSize="10" HorizontalAlignment="Right" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                        </DockPanel>
                                        <ProgressBar x:Name="CriticTokenUsageProgressBar" Grid.Row="1" Minimum="0" Maximum="100" Value="0" Style="{StaticResource WorkplaceTokenMeterProgressBarStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="RevisionNoticeBlock" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0" Text="Issues were found and the output was revised." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="0" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0">
                                <Button x:Name="WorkplaceCloudModeButton" Content="Cloud Off" Click="WorkplaceCloudModeButton_Click" Width="100" Height="36"
                                        Style="{StaticResource SubtleButtonStyle}" Margin="4,0" ToolTip="Use local council models"/>
                                <Button x:Name="WebSearchToggleButton" Content="Web" Click="WebSearchToggleButton_Click" Width="54" Height="36"
                                        Style="{StaticResource SubtleButtonStyle}" Margin="4,0" ToolTip="Web Search tool enabled"/>
                                <Button x:Name="CouncilPetToggleButton" Content="Bit" Click="CouncilPetToggleButton_Click" Width="54" Height="36"
                                        Style="{StaticResource SubtleButtonStyle}" Margin="4,0" ToolTip="Show the draggable Council Bit status companion"/>
                                <Button x:Name="StopButton" Content="⏹ Stop" Click="StopMessage_Click" Width="80" Height="36"
                                        Style="{StaticResource SubtleButtonStyle}" Foreground="{StaticResource PrimaryAccentBrush}" IsEnabled="False" Margin="4,0"/>
                                <Button x:Name="SendButton" Content="Run Council" Click="SendMessage_Click" Width="110" Height="36"
                                        Style="{StaticResource PremiumButtonStyle}" Margin="4,0"/>
                            </StackPanel>
                            <avalonedit:TextEditor x:Name="QueryInput"
                                     Background="{StaticResource NotebookBackgroundBrush}" Foreground="{StaticResource NotebookTextBrush}"
                                     FontFamily="Segoe UI" FontSize="13" KeyDown="QueryInput_KeyDown"
                                     WordWrap="True" ShowLineNumbers="False"
                                     HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                                     Height="72" MinHeight="72" MaxHeight="72"/>
                        </DockPanel>
                    </Border>
                    <TextBlock Text="Architect/Critic in chat  •  Builder in Project Canvas" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- System notifications dropdown (compact, non-intrusive) -->
            <Border DockPanel.Dock="Top" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,0,0,1" Padding="12,4">
                <DockPanel>
                    <Button x:Name="NotificationToggleButton" Click="NotificationToggle_Click" DockPanel.Dock="Left" Style="{StaticResource SubtleButtonStyle}" Padding="6,2" Height="22">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▸" x:Name="NotificationToggleArrow" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="System Log" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" VerticalAlignment="Center"/>
                            <Border x:Name="NotificationBadge" Background="{StaticResource PrimaryAccentBrush}" CornerRadius="7" MinWidth="14" Height="14" Margin="6,0,0,0" Padding="3,0" Visibility="Collapsed">
                                <TextBlock x:Name="NotificationBadgeText" Text="0" FontSize="9" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Content="Clear" Click="ClearNotifications_Click" DockPanel.Dock="Right" Style="{StaticResource SubtleButtonStyle}" Padding="6,1" FontSize="9" Height="20" Margin="0,0,2,0"/>
                </DockPanel>
            </Border>
            <Border x:Name="NotificationDropdownPanel" DockPanel.Dock="Top" Visibility="Collapsed" MaxHeight="180" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,0,0,1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <ItemsControl x:Name="NotificationList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,1" Padding="8,4" CornerRadius="6"
                                        Background="{Binding CardBackground}"
                                        BorderBrush="{Binding AccentBrush}" BorderThickness="2,0,0,0">
                                    <DockPanel>
                                        <TextBlock Text="{Binding TimestampLabel}" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Top" Width="52" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding RoleLabel}" FontSize="9" FontWeight="SemiBold" Foreground="{Binding AccentBrush}" DockPanel.Dock="Left" VerticalAlignment="Top" Width="46" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding FormattedContent}" TextWrapping="Wrap" FontSize="10" FontFamily="Segoe UI" Foreground="{StaticResource DarkSecondaryBrush}" MaxHeight="36" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- Agentic Pause live status bar                              -->
            <!-- Floats just above the chat area; collapsed when idle.      -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border x:Name="AgenticPauseBanner"
                    DockPanel.Dock="Top"
                    Visibility="Collapsed"
                    Opacity="0"
                    Padding="14,5,14,5"
                    Background="#171615"
                    BorderBrush="#FF3B3B"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Left: animated pulse dot -->
                    <Border x:Name="AgenticPulseDot"
                            Width="7" Height="7"
                            CornerRadius="4"
                            Background="#FF3B3B"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            DockPanel.Dock="Left"/>
                    <!-- Right: pause budget indicator (e.g. 2/3) -->
                    <Border Background="#211F1D"
                            BorderBrush="#302D2A"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="7,2"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right">
                        <TextBlock x:Name="AgenticPauseBudgetText"
                                   Text="0 / 3"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#8A8279"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <!-- Centre: descriptive status text -->
                    <TextBlock x:Name="AgenticPauseStatusBlock"
                               Text=""
                               FontSize="10"
                               FontStyle="Italic"
                               Foreground="#EDE8E3"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Opacity="1"
                               Visibility="Visible"/>
                </DockPanel>
            </Border>

            <!-- Chat display (fills remaining space — shows only user/architect/builder/critic/sandbox) -->
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{StaticResource NotebookBackgroundBrush}" Padding="12,12" PreviewMouseWheel="ChatScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="ChatCardsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="12,7" CornerRadius="10"
                                    Background="{Binding CardBackground}"
                                    BorderBrush="{Binding AccentBrush}" BorderThickness="3,0,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,3">
                                        <TextBlock Text="{Binding RoleLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding AccentBrush}"/>
                                        <Button x:Name="CopyWorkplaceMessageButton" Content="Copy" Click="CopyWorkplaceMessage_Click" Tag="{Binding}" FontSize="9" Padding="6,1" Margin="0,0,6,0" DockPanel.Dock="Right" Style="{StaticResource SubtleButtonStyle}"/>
                                        <TextBlock Text="{Binding TimestampLabel}" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                    </DockPanel>
                                    <!-- Full message shown (no inner scrollbar). Slightly smaller font
                                         and tightened line spacing keep each response compact so it
                                         takes less vertical space in the chat column. -->
                                    <local:ShimmerTextBlock x:Name="WorkplaceCardGenerationStatusText"
                                                            Text="{Binding GenerationStatusText}"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            BaseColor="#A1A1AA"
                                                            HighlightColor="#FFFFFF"
                                                            ShimmerDurationSeconds="2"
                                                            TextTrimming="CharacterEllipsis"
                                                            Visibility="Collapsed"/>
                                    <FlowDocumentScrollViewer x:Name="WorkplaceCardContentText"
                                                              Document="{Binding FormattedDocument}"
                                                              Background="Transparent"
                                                              BorderThickness="0"
                                                              Padding="0"
                                                              IsToolBarVisible="False"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              IsTabStop="False"/>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Role}" Value="user">
                                    <Setter TargetName="CopyWorkplaceMessageButton" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ShowGeneratingStatusInCard}" Value="True">
                                    <Setter TargetName="WorkplaceCardGenerationStatusText" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="WorkplaceCardContentText" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGeneratingStatus}" Value="True">
                                    <Setter TargetName="WorkplaceCardContentText" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ═══════════════════════════════════════════ -->
        <!-- RIGHT — Project Canvas                      -->
        <!-- ═══════════════════════════════════════════ -->
        <Border x:Name="ProjectCanvasCollapsedHandle" Grid.Column="2" Visibility="Collapsed" Width="56" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1,0,0,0">
            <Button x:Name="ProjectCanvasRestoreButton" Content="Canvas" Click="ProjectCanvasToggleButton_Click" Style="{StaticResource PanelToggleButtonStyle}" ToolTip="Show project canvas" VerticalAlignment="Center" Padding="4" FontSize="10"/>
        </Border>

        <Border x:Name="ProjectCanvasPane" Grid.Column="2" MinWidth="320" MaxWidth="640" Width="500" Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1,0,0,0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Canvas header -->
                <Border Grid.Row="0" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="0"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock x:Name="CanvasTitleBlock" Text="Project Canvas" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="CanvasSubtitleBlock" Text="Builder output rendered here." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="CanvasDiffSummaryBlock" Text="" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,2,0,0" Visibility="Collapsed" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <StackPanel x:Name="CanvasArtifactTogglePanel" Orientation="Horizontal" Margin="0,0,8,0" Visibility="Collapsed">
                                <Button x:Name="CanvasCodeViewButton" Content="Code" Click="CanvasCodeViewButton_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" MinWidth="58" Height="30" Padding="10,0" Margin="0,0,4,0"/>
                                <Button x:Name="CanvasPreviewViewButton" Content="Preview" Click="CanvasPreviewViewButton_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" MinWidth="78" Height="30" Padding="12,0"/>
                            </StackPanel>
                            <Button x:Name="CopyCanvasButton" Click="CopyCanvasButton_Click" Style="{StaticResource PanelToggleButtonStyle}" ToolTip="Copy to clipboard" Margin="0,0,8,0" Width="30" Height="30">
                                <Canvas Width="14" Height="14">
                                    <Rectangle Canvas.Left="0" Canvas.Top="3" Width="9" Height="9" Stroke="{StaticResource DarkSecondaryBrush}" StrokeThickness="1.4" RadiusX="1.5" RadiusY="1.5"/>
                                    <Rectangle Canvas.Left="4" Canvas.Top="0" Width="9" Height="9" Stroke="{StaticResource NotebookTextBrush}" StrokeThickness="1.4" Fill="{StaticResource NotebookBackgroundBrush}" RadiusX="1.5" RadiusY="1.5"/>
                                </Canvas>
                            </Button>
                            <Button x:Name="RunCodeButton" Content="▶ Run" Margin="0,0,8,0" Click="RunCodeButton_Click" Style="{StaticResource PremiumButtonStyle}" FontSize="10" MinWidth="72" Height="30" Padding="10,0" ToolTip="Execute code in sandbox"/>
                            <Button x:Name="ShowDiffButton" Content="Diff" Margin="0,0,8,0" Click="ShowDiffButton_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" MinWidth="52" Height="30" Padding="10,0" ToolTip="Compare the current canvas source with its previous generated version" Visibility="Collapsed"/>
                            <Button x:Name="CodeOutputToggleButton" Content="⌄" Margin="0,0,8,0" Click="CodeOutputToggleButton_Click" Style="{StaticResource PanelToggleButtonStyle}" ToolTip="Hide code output" Width="30" Height="30"/>
                            <Button x:Name="UndoCodebaseChangesButton" Content="Undo" Margin="0,0,8,0" Click="UndoCodebaseChanges_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" MinWidth="62" Height="30" Padding="10,0" ToolTip="Undo the last applied codebase patch" Visibility="Collapsed" IsEnabled="False"/>
                            <Button x:Name="AcceptCodebaseChangesButton" Content="Accept" Margin="0,0,8,0" Click="AcceptCodebaseChanges_Click" Style="{StaticResource PremiumButtonStyle}" FontSize="10" MinWidth="64" Height="30" Padding="10,0" ToolTip="Accept proposed codebase changes" Visibility="Collapsed" IsEnabled="False"/>
                            <Button x:Name="RejectCodebaseChangesButton" Content="Reject" Margin="0,0,8,0" Click="RejectCodebaseChanges_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" MinWidth="62" Height="30" Padding="10,0" ToolTip="Reject proposed codebase changes" Visibility="Collapsed" IsEnabled="False"/>
                            <Button x:Name="CanvasMoreActionsButton" Content="..." Margin="0,0,8,0" Click="CanvasMoreActionsButton_Click" Style="{StaticResource PanelToggleButtonStyle}" ToolTip="More canvas actions" Width="30" Height="30" Visibility="Collapsed">
                                <Button.ContextMenu>
                                    <ContextMenu Background="{StaticResource NotebookBackgroundBrush}"
                                                 BorderBrush="{StaticResource NotebookBorderBrush}"
                                                 Foreground="{StaticResource NotebookTextBrush}"
                                                 BorderThickness="1"
                                                 Padding="4">
                                        <ContextMenu.ItemContainerStyle>
                                            <Style TargetType="{x:Type MenuItem}">
                                                <Setter Property="Background" Value="{StaticResource NotebookBackgroundBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource NotebookTextBrush}"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Padding" Value="12,7"/>
                                                <Setter Property="MinWidth" Value="132"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type MenuItem}">
                                                            <Border x:Name="MenuItemBorder"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    SnapsToDevicePixels="True">
                                                                <ContentPresenter ContentSource="Header"
                                                                                  RecognizesAccessKey="True"
                                                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsHighlighted" Value="True">
                                                                    <Setter TargetName="MenuItemBorder" Property="Background" Value="{StaticResource NotebookSurfaceBrush}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryAccentBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="MenuItemBorder" Property="Opacity" Value="0.45"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ContextMenu.ItemContainerStyle>
                                        <MenuItem x:Name="CanvasMoreCopyItem" Header="Copy source" Click="CanvasMoreCopyItem_Click"/>
                                        <MenuItem x:Name="CanvasMoreDiffItem" Header="Show diff" Click="CanvasMoreDiffItem_Click"/>
                                        <MenuItem x:Name="CanvasMoreOutputItem" Header="Hide output" Click="CanvasMoreOutputItem_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button x:Name="ProjectCanvasToggleButton" Content="›" Click="ProjectCanvasToggleButton_Click" Style="{StaticResource PanelToggleButtonStyle}" ToolTip="Hide project canvas" Width="30" Height="30"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Code editor -->
                <Border x:Name="CodeOutputPanel" Grid.Row="1" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <avalonedit:TextEditor x:Name="ProjectCanvasEditor"
                                           Background="{StaticResource NotebookBackgroundBrush}"
                                           Foreground="{StaticResource NotebookTextBrush}"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           ShowLineNumbers="True"
                                           IsReadOnly="True"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"/>
                        <Grid x:Name="CanvasArtifactPreviewHost" Visibility="Collapsed" Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <wv2:WebView2 x:Name="CanvasArtifactWebView"
                                          Grid.Row="0"
                                          DefaultBackgroundColor="#00000000"
                                          Margin="0"
                                          Visibility="Visible"/>
                            <Border Grid.Row="1" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="0,1,0,0" Padding="10,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="CopyCanvasArtifactSourceButton" Content="Copy Source" Click="CopyCanvasArtifactSourceButton_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,0,8,0" Padding="8,2"/>
                                    <Button x:Name="SaveCanvasArtifactButton" Content="Save" Click="SaveCanvasArtifactButton_Click" Style="{StaticResource SubtleButtonStyle}" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Padding="8,2"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ScrollViewer x:Name="DiffViewerScroller" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="{StaticResource NotebookBackgroundBrush}">
                            <ItemsControl x:Name="DiffViewerLines">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

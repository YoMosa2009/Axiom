<Window x:Class="Malx_AI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Malx_AI"
        Title="Axiom - Chat" Height="900" Width="1600" MinWidth="1040" MinHeight="640" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/Malx_Logo.ico"
        AllowsTransparency="False" Background="{StaticResource NotebookBackgroundBrush}" Foreground="{StaticResource NotebookTextBrush}"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <QuadraticEase x:Key="FastEaseOut" EasingMode="EaseOut"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="ActiveNavigationTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#B8924A"/>
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="#302D2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.86"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CodeBlockToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A8279"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2826"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InactiveNavigationTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A8279"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarFlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2826"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarFlatButtonStyle}">
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="#302D2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2826"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatHistoryItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2826"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#302D2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkplaceActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#24211F"/>
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="#4A4035"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D2926"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#B8924A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C1A18"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#70685F"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkplaceDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource WorkplaceActionButtonStyle}">
            <Setter Property="Background" Value="#231C1C"/>
            <Setter Property="Foreground" Value="#D9A29A"/>
            <Setter Property="BorderBrush" Value="#5A3631"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="WorkplaceHistoryItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C1A18"/>
            <Setter Property="Foreground" Value="#DCD5CB"/>
            <Setter Property="BorderBrush" Value="#302D2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="accentRail"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding BorderBrush}"
                                        CornerRadius="8,0,0,8"
                                        Opacity="0.45"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24211F"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A4035"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatInputIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A8279"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2826"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8A8279"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatInputUtilityButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#24211F"/>
            <Setter Property="Foreground" Value="#BFB6AA"/>
            <Setter Property="BorderBrush" Value="#36312D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D2926"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4B4239"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D1B19"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#70685F"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TokenMeterProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="#302D2A"/>
            <Setter Property="Foreground" Value="#5FAF7D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot"
                              Height="{TemplateBinding Height}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatInputToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource ChatInputIconButtonStyle}">
            <Setter Property="Foreground" Value="#8A8279"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2826"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="Opacity" Value="1">
                                <Setter TargetName="border" Property="Background" Value="#B8924A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#B8924A"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Opacity" Value="1"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#B8924A"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8A8279"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatInputSendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#B8924A"/>
            <Setter Property="Foreground" Value="#EDE8E3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#302D2A"/>
                                <Setter Property="Foreground" Value="#8A8279"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding ElementName=InputBox, Path=Text}" Value="">
                                <Setter Property="Background" Value="#302D2A"/>
                                <Setter Property="Foreground" Value="#8A8279"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource NotebookTextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A2826"/>
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A3328"/>
                                <Setter Property="Foreground" Value="#F5D591"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#665F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#171615"/>
            <Setter Property="Foreground" Value="{StaticResource NotebookTextBrush}"/>
            <Setter Property="BorderBrush" Value="#302D2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid TextElement.Foreground="{TemplateBinding Foreground}">
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Path x:Name="DropDownArrow"
                                                      Width="8"
                                                      Height="5"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"
                                                      Fill="#8A8279"
                                                      Stretch="Uniform"
                                                      Data="M 0 0 L 8 0 L 4 5 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#4A443D"/>
                                                <Setter TargetName="DropDownArrow" Property="Fill" Value="#EDE8E3"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#211F1D"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#B8924A"/>
                                                <Setter TargetName="DropDownArrow" Property="Fill" Value="#F5D591"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,30,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220"
                                        Margin="0,4,0,0"
                                        Padding="4"
                                        Background="#171615"
                                        BorderBrush="#302D2A"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#B8924A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#665F58"/>
                                <Setter Property="Background" Value="#211F1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatModeSelectorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8A8279"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4,6,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,1"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#EDE8E3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8A8279"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource NotebookBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="304"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MODE TABS -->
        <Border x:Name="NavigationBar" Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource DarkSidebarBrush}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ChatTabButton" Content="💬 Chat" Click="SwitchToChat_Click" Height="32" Width="120"
                        Style="{StaticResource ActiveNavigationTabButtonStyle}" Margin="0,0,8,0"/>
                <Button x:Name="WorkplaceTabButton" Content="📄 Workplace" Click="SwitchToWorkplace_Click" Height="32" Width="120"
                        Style="{StaticResource InactiveNavigationTabButtonStyle}" Margin="0,0,8,0"/>
                <Button x:Name="PersonaTabButton" Content="🧠 Persona" Click="SwitchToPersona_Click" Height="32" Width="120"
                        Style="{StaticResource InactiveNavigationTabButtonStyle}" Margin="0,0,0,0"/>
                <Button x:Name="NeuronTabButton" Content="🧬 Neuron" Click="SwitchToNeuron_Click" Height="32" Width="120"
                        Style="{StaticResource InactiveNavigationTabButtonStyle}" Margin="8,0,0,0"/>
                <Button x:Name="SidebarCollapseButton" Content="◂" Click="SidebarCollapseToggle_Click" Height="32" Width="32"
                        Style="{StaticResource InactiveNavigationTabButtonStyle}" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- LEFT SIDEBAR -->
        <Border x:Name="SidebarBorder" Grid.Row="1" Grid.Column="0" Background="#171615" BorderThickness="0,0,1,0" BorderBrush="#302D2A">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="14,12,14,16">
                    <Rectangle Height="1" Fill="#302D2A" Margin="0,0,0,14"/>
                    <Button x:Name="ImportModelSidebarButton" Content="+ Import AI Model" Click="ImportModel_Click" Height="40"
                            Margin="0,0,0,8" Style="{StaticResource PremiumButtonStyle}" FontSize="12" Background="#B8924A" BorderBrush="#B8924A" Foreground="#EDE8E3"/>
                    <Button x:Name="DownloadDefaultModelSidebarButton" Content="↓ Download default model" Click="DownloadDefaultModel_Click" Height="36"
                            Margin="0,0,0,8" Style="{StaticResource SidebarOutlineButtonStyle}" FontSize="12"/>
                    <Button Content="⚙ Settings" Click="Settings_Click" Height="36" Margin="0,0,0,8"
                            Style="{StaticResource SidebarOutlineButtonStyle}" FontSize="12"/>
                    <Button x:Name="DeleteChatSidebarButton" Content="Delete chat" Click="DeleteChat_Click" Height="34"
                            Style="{StaticResource SidebarFlatButtonStyle}" FontSize="11" Foreground="#8A8279"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="14,18,14,0">
                    <TextBlock Text="Axiom" FontSize="26" FontWeight="Bold" Foreground="#EDE8E3" FontFamily="Georgia"/>
                    <Button x:Name="NewChatButton" DockPanel.Dock="Top" Content="+ New chat" Click="NewChat_Click" Height="40" Margin="0,20,0,0"
                            Style="{StaticResource SidebarFlatButtonStyle}" FontSize="16" Padding="14,10"/>
                    <Button x:Name="HistorySectionToggle" DockPanel.Dock="Top" Content="▾ Recents" Click="SidebarHistoryToggle_Click" Height="32"
                            Margin="0,20,0,0" Style="{StaticResource SidebarFlatButtonStyle}" FontSize="12" Foreground="#8A8279" Padding="0,6"/>
                </StackPanel>

                <Button x:Name="WorkplaceHistorySectionToggle" DockPanel.Dock="Top" Content="▾ Workplace Chats" Click="WorkplaceSidebarHistoryToggle_Click" Height="34"
                        Margin="14,10,14,0" Style="{StaticResource SidebarFlatButtonStyle}" FontSize="12" Foreground="#8A8279" Padding="0,6" Visibility="Collapsed"/>

                <Border x:Name="ChatHistorySectionContainer" DockPanel.Dock="Top" Opacity="1" MaxHeight="500">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <StackPanel x:Name="ChatHistoryStack" Margin="14,0,14,0"/>
                    </ScrollViewer>
                </Border>

                <Border x:Name="WorkplaceHistorySectionContainer" DockPanel.Dock="Top" Opacity="1" MaxHeight="420" Visibility="Collapsed">
                    <StackPanel Margin="14,8,14,0">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="78"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="NewWorkplaceButton" Click="NewWorkplace_Click" Height="36" Margin="0,0,8,0" Style="{StaticResource WorkplaceActionButtonStyle}" ToolTip="Create a new workplace chat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold" Foreground="#B8924A" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="New Workplace" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="DeleteWorkplaceButton" Grid.Column="1" Click="DeleteWorkplace_Click" Height="36" Style="{StaticResource WorkplaceDeleteButtonStyle}" ToolTip="Delete the current workplace chat">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="x" FontSize="12" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                            <StackPanel x:Name="WorkplaceHistoryStack"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- CONTENT CONTAINER -->
        <Grid x:Name="ContentContainer" Grid.Row="1" Grid.Column="1" Background="{StaticResource NotebookBackgroundBrush}">
            <!-- CHAT VIEW (default) -->
            <DockPanel x:Name="ChatView" Background="{StaticResource NotebookBackgroundBrush}">
                <!-- Header -->
                <Border x:Name="ChatHeaderBorder" DockPanel.Dock="Top" BorderThickness="0" Padding="28,14,28,4" Background="Transparent">
                    <StackPanel>
                        <TextBlock x:Name="HeaderModelName" Text="No Model Loaded" FontSize="12" Foreground="#8A8279" 
                                   FontFamily="Segoe UI" Margin="0,0,0,0"/>
                        <Border x:Name="CloudContextNoticeBorder"
                                Visibility="Collapsed"
                                 Margin="0,8,0,0"
                                Padding="10,6"
                                Background="#211F1D"
                                BorderBrush="#302D2A"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="CloudContextNoticeText"
                                       Text=""
                                       FontSize="10"
                                       Foreground="#8A8279"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <Border x:Name="TokenUsagePanel"
                                Margin="0,8,0,0"
                                Padding="10,8"
                                Width="360"
                                HorizontalAlignment="Left"
                                Background="#1C1A18"
                                BorderBrush="#302D2A"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,5">
                                    <TextBlock Text="Context"
                                               DockPanel.Dock="Left"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#BFB6AA"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TokenUsageLabel"
                                               Text="0 / 0 tok"
                                               DockPanel.Dock="Right"
                                               FontSize="10"
                                               Foreground="#8A8279"
                                               FontFamily="Segoe UI"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>

                                <ProgressBar x:Name="TokenUsageProgressBar"
                                             Grid.Row="1"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Style="{StaticResource TokenMeterProgressBarStyle}"/>

                                <StackPanel x:Name="CompactionHealthGrid" Grid.Row="2" Margin="0,8,0,0" Visibility="Collapsed">
                                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                        <TextBlock Text="Compaction"
                                                   DockPanel.Dock="Left"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#BFB6AA"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock x:Name="CompactionHealthLabel"
                                                   Text=""
                                                   DockPanel.Dock="Right"
                                                   FontSize="10"
                                                   Foreground="#8A8279"
                                                   FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <ProgressBar x:Name="CompactionThresholdBar"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"
                                                 FlowDirection="LeftToRight"
                                                 Style="{StaticResource TokenMeterProgressBarStyle}"/>
                                </StackPanel>

                                <TextBlock x:Name="CompactionStatusLabel"
                                           Grid.Row="3"
                                           Text=""
                                           FontSize="9"
                                           Foreground="#8A8279"
                                           Visibility="Collapsed"
                                           Margin="0,6,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorNotificationBar" DockPanel.Dock="Top" Visibility="Collapsed" Padding="32,8" Background="{StaticResource NotebookSurfaceBrush}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource NotebookBorderBrush}">
                    <TextBlock x:Name="ErrorNotificationText" Foreground="{StaticResource PrimaryAccentBrush}" FontSize="12" FontFamily="Segoe UI"/>
                </Border>

                <!-- Settings panel is now rendered as a global overlay in ContentContainer -->

                <!-- Chat Area -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Display -->
                    <Grid Grid.Row="0">
                        <ListBox x:Name="ChatDisplay"
                                 Margin="0"
                                  Padding="32,18,32,24"
                                 HorizontalAlignment="Stretch"
                                 Background="{StaticResource NotebookBackgroundBrush}"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="False"
                                  PreviewMouseWheel="ChatDisplay_PreviewMouseWheel"
                                  VirtualizingPanel.IsVirtualizing="False"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="BubbleBorder" CornerRadius="12" Padding="16,10" Margin="0,4"
                                                MaxWidth="720">
                                            <StackPanel>
                                                <TextBlock x:Name="ModelLabelBlock" Text="{Binding ModelLabel}" FontSize="9" Foreground="{StaticResource DarkSecondaryBrush}" HorizontalAlignment="Right" Margin="0,0,0,4" Visibility="Collapsed"/>
                                                <Border x:Name="CodeBlockContainer"
                                                        Margin="0,0,0,10"
                                                        Padding="0"
                                                        Background="#211F1D"
                                                        BorderBrush="#302D2A"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Visibility="Collapsed">
                                                    <StackPanel>
                                                        <DockPanel Margin="10,8,10,0">
                                                            <TextBlock Text="{Binding CodeBlockHeaderText}" FontSize="10" FontWeight="SemiBold" Foreground="#8A8279" VerticalAlignment="Center"/>
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                                <Button Content="Copy"
                                                                        Click="CopyCodeBlock_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource CodeBlockToggleButtonStyle}"
                                                                        Margin="0,0,4,0"/>
                                                                <Button Content="{Binding CodeBlockToggleText}"
                                                                        Click="CodeBlockToggle_Click"
                                                                        Tag="{Binding}"
                                                                        Style="{StaticResource CodeBlockToggleButtonStyle}"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                        <ItemsControl x:Name="CodeBlockItemsControl" ItemsSource="{Binding CodeBlocks}" Margin="10,8,10,10">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,0,0,8"
                                                                            Padding="10,8"
                                                                            Background="#171615"
                                                                            BorderBrush="#302D2A"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Language}" FontSize="9" FontWeight="SemiBold" Foreground="#8A8279" Margin="0,0,0,6">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding HasLanguage}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <TextBox Text="{Binding Code, Mode=OneWay}"
                                                                                     TextWrapping="NoWrap"
                                                                                     HorizontalScrollBarVisibility="Auto"
                                                                                     VerticalScrollBarVisibility="Auto"
                                                                                     Background="Transparent"
                                                                                     BorderThickness="0"
                                                                                     Padding="0"
                                                                                     FontFamily="Consolas"
                                                                                     FontSize="12"
                                                                                     Foreground="#EDE8E3"
                                                                                     IsReadOnly="True"
                                                                                     IsReadOnlyCaretVisible="False"
                                                                                     Cursor="Arrow"
                                                                                     SelectionBrush="{StaticResource PrimaryAccentBrush}"
                                                                                     SelectionOpacity="0.3">
                                                                                <TextBox.Style>
                                                                                    <Style TargetType="TextBox">
                                                                                        <Setter Property="Template">
                                                                                            <Setter.Value>
                                                                                                <ControlTemplate TargetType="TextBox">
                                                                                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Background="Transparent"/>
                                                                                                </ControlTemplate>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel x:Name="ThinkingPanel" Margin="0,0,0,10" Visibility="Collapsed">
                                                    <Border Background="#211F1D" BorderBrush="#302D2A" BorderThickness="1" CornerRadius="10" Padding="10,8">
                                                        <StackPanel>
                                                            <Button x:Name="ThinkingToggleButton" Click="ThinkingToggle_Click" Tag="{Binding}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left" Cursor="Hand" IsEnabled="False" Visibility="Collapsed">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock x:Name="ThinkingChevron" Text="▸" FontSize="11" Foreground="#8A8279" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding ThinkingHeaderText}" FontSize="11" FontWeight="SemiBold" Foreground="#EDE8E3" VerticalAlignment="Center"/>
                                                                    <TextBlock x:Name="ThinkingDots" Text="" FontSize="11" Foreground="#FF9A3D" VerticalAlignment="Center" Margin="6,0,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsThinkingInProgress}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                        <TextBlock.Triggers>
                                                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                                <BeginStoryboard>
                                                                                    <Storyboard RepeatBehavior="Forever">
                                                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Text">
                                                                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value=" ✦"/>
                                                                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.35" Value=" ✦ ✦"/>
                                                                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.7" Value=" ✦ ✦ ✦"/>
                                                                                            <DiscreteObjectKeyFrame KeyTime="0:0:1.05" Value=" ✦ ✦"/>
                                                                                        </ObjectAnimationUsingKeyFrames>
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.55" To="1" Duration="0:0:0.55" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger>
                                                                        </TextBlock.Triggers>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Button>
                                                            <Border x:Name="ThinkingContentBorder" Margin="0,8,0,0" Padding="10,8" Background="#171615" BorderBrush="#302D2A" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                                                                <Grid>
                                                                    <TextBox x:Name="ThinkingText"
                                                                             Text="{Binding FormattedThinkingContent, Mode=OneWay}" TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                                                                             Foreground="#EDE8E3" Background="Transparent" BorderThickness="0" Padding="0"
                                                                             IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Arrow"
                                                                             SelectionBrush="{StaticResource PrimaryAccentBrush}" SelectionOpacity="0.3">
                                                                        <TextBox.Style>
                                                                            <Style TargetType="TextBox">
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="TextBox">
                                                                                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Background="Transparent"/>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </Style>
                                                                        </TextBox.Style>
                                                                    </TextBox>
                                                                    <local:RenderedMessageView x:Name="RenderedThinkingBubble"
                                                                                               RawText="{Binding RichThinkingContent, Mode=OneWay}"
                                                                                               PlainText="{Binding FormattedThinkingContent, Mode=OneWay}"
                                                                                               IsHtmlRenderingEnabled="False"
                                                                                               HorizontalAlignment="Stretch"
                                                                                               Visibility="Collapsed"/>
                                                                </Grid>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <local:ShimmerTextBlock x:Name="AssistantGenerationStatusText"
                                                                        Text="{Binding GenerationStatusText}"
                                                                        Margin="0,0,0,8"
                                                                        FontSize="13"
                                                                        FontWeight="SemiBold"
                                                                        BaseColor="#71717A"
                                                                        HighlightColor="#EDE8E3"
                                                                        ShimmerDurationSeconds="2"
                                                                        TextTrimming="CharacterEllipsis"
                                                                        Visibility="Collapsed"/>
                                                <TextBox x:Name="BubbleText" Text="{Binding DisplayFormattedContent, Mode=OneWay}" TextWrapping="Wrap" FontSize="13" FontFamily="Segoe UI"
                                                         Foreground="{StaticResource NotebookTextBrush}" Background="Transparent" BorderThickness="0" Padding="0"
                                                         IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Arrow"
                                                         SelectionBrush="{StaticResource PrimaryAccentBrush}" SelectionOpacity="0.3">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="TextBox">
                                                                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Background="Transparent"/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDisplayContent}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <local:RenderedMessageView x:Name="RenderedBubble"
                                                                           RawText="{Binding RichRenderContent, Mode=OneWay}"
                                                                            PlainText="{Binding DisplayFormattedContent, Mode=OneWay}"
                                                                           IsHtmlRenderingEnabled="False"
                                                                           HorizontalAlignment="Stretch"
                                                                           Visibility="Collapsed"/>
                                                <WrapPanel x:Name="ActionButtonPanel" HorizontalAlignment="Right" Margin="0,8,0,0" Visibility="Collapsed">
                                                    <Button x:Name="EditResendActionButton" Content="Edit &amp; Resend" Click="EditResendMessage_Click" Tag="{Binding}" FontSize="10" Padding="8,2" MinWidth="92" Margin="0,0,5,4" Visibility="Collapsed" Style="{StaticResource SubtleButtonStyle}"/>
                                                    <Button x:Name="RegenerateActionButton" Content="Regenerate" Click="RegenerateMessage_Click" Tag="{Binding}" FontSize="10" Padding="8,2" MinWidth="78" Margin="0,0,5,4" Visibility="Collapsed" Style="{StaticResource SubtleButtonStyle}"/>
                                                    <Button x:Name="RetryCloudActionButton" Content="Retry Other" Click="RetryOtherCloudModel_Click" Tag="{Binding}" FontSize="10" Padding="8,2" MinWidth="78" Margin="0,0,5,4" Visibility="Collapsed" Style="{StaticResource SubtleButtonStyle}"/>
                                                    <Button x:Name="PinActionButton" Content="Pin" Click="PinMessage_Click" Tag="{Binding}" FontSize="10" Padding="8,2" MinWidth="40" Margin="0,0,5,4" Style="{StaticResource SubtleButtonStyle}"/>
                                                    <Button Content="Branch" Click="BranchMessage_Click" Tag="{Binding}" FontSize="10" Padding="8,2" MinWidth="56" Margin="0,0,5,4" Style="{StaticResource SubtleButtonStyle}"/>
                                                    <Button Content="Copy" Click="CopyMessage_Click" Tag="{Binding}" FontSize="10" Padding="8,2" MinWidth="46" Margin="0,0,0,4" Style="{StaticResource SubtleButtonStyle}"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                <Setter TargetName="BubbleBorder" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="BubbleBorder" Property="Margin" Value="80,4,8,4"/>
                                                <Setter TargetName="BubbleBorder" Property="Background" Value="{StaticResource NotebookSurfaceBrush}"/>
                                                <Setter TargetName="BubbleBorder" Property="BorderBrush" Value="{StaticResource NotebookBorderBrush}"/>
                                                <Setter TargetName="BubbleBorder" Property="BorderThickness" Value="1"/>
                                                <Setter TargetName="ActionButtonPanel" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="EditResendActionButton" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="PinActionButton" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                <Setter TargetName="BubbleBorder" Property="HorizontalAlignment" Value="Left"/>
                                                <Setter TargetName="BubbleBorder" Property="Margin" Value="8,4,80,4"/>
                                                <Setter TargetName="BubbleBorder" Property="MinWidth" Value="300"/>
                                                <Setter TargetName="BubbleBorder" Property="MaxWidth" Value="780"/>
                                                <Setter TargetName="BubbleBorder" Property="Background" Value="{StaticResource AiMessageBrush}"/>
                                                <Setter TargetName="BubbleBorder" Property="BorderBrush" Value="{StaticResource NotebookBorderBrush}"/>
                                                <Setter TargetName="BubbleBorder" Property="BorderThickness" Value="1"/>
                                                <Setter TargetName="ModelLabelBlock" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ActionButtonPanel" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="RegenerateActionButton" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="RetryCloudActionButton" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ShouldShowGenerationStatus}" Value="True">
                                                <Setter TargetName="AssistantGenerationStatusText" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                             <MultiDataTrigger>
                                                 <MultiDataTrigger.Conditions>
                                                     <Condition Binding="{Binding Role}" Value="assistant"/>
                                                     <Condition Binding="{Binding IsStreaming}" Value="False"/>
                                                    <Condition Binding="{Binding PreferPlainTextRendering}" Value="False"/>
                                                    <Condition Binding="{Binding SupportsRichRendering}" Value="True"/>
                                                    <Condition Binding="{Binding HasCodeBlocks}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="BubbleText" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="RenderedBubble" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="RenderedBubble" Property="IsHtmlRenderingEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Role}" Value="user"/>
                                                    <Condition Binding="{Binding SupportsRichRendering}" Value="True"/>
                                                    <Condition Binding="{Binding HasCodeBlocks}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="BubbleText" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="RenderedBubble" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="RenderedBubble" Property="IsHtmlRenderingEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Role}" Value="assistant"/>
                                                    <Condition Binding="{Binding HasCodeBlocks}" Value="True"/>
                                                    <Condition Binding="{Binding IsStreaming}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="CodeBlockContainer" Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Role}" Value="assistant"/>
                                                    <Condition Binding="{Binding HasCodeBlocks}" Value="True"/>
                                                    <Condition Binding="{Binding IsCodeBlockCollapsed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="CodeBlockItemsControl" Property="Visibility" Value="Collapsed"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Role}" Value="assistant"/>
                                                    <Condition Binding="{Binding ShouldShowThinkingHeader}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="ThinkingPanel" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ThinkingToggleButton" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ThinkingToggleButton" Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Role}" Value="assistant"/>
                                                    <Condition Binding="{Binding IsThinkingExpanded}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="ThinkingContentBorder" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ThinkingChevron" Property="Text" Value="▾"/>
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="system">
                                                <Setter TargetName="BubbleBorder" Property="HorizontalAlignment" Value="Center"/>
                                                <Setter TargetName="BubbleBorder" Property="Background" Value="Transparent"/>
                                                <Setter TargetName="BubbleBorder" Property="Padding" Value="8,6"/>
                                                <Setter TargetName="BubbleBorder" Property="MaxWidth" Value="900"/>
                                                <Setter TargetName="BubbleText" Property="Foreground" Value="{StaticResource DarkSecondaryBrush}"/>
                                                <Setter TargetName="BubbleText" Property="FontSize" Value="11"/>
                                                <Setter TargetName="BubbleText" Property="TextAlignment" Value="Center"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                <Setter TargetName="RenderedBubble" Property="Margin" Value="0"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel x:Name="EmptyChatGreetingPanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                            <Image x:Name="EmptyChatLogoImage"
                                   Width="98"
                                   Height="98"
                                   Margin="0,0,0,8"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock x:Name="EmptyChatGreetingText"
                                        Text="Ready when you are"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                        FontSize="22"
                                       FontWeight="Light"
                                         Foreground="#EDE8E3"
                                       TextAlignment="Center"
                                        IsHitTestVisible="False"
                                        Visibility="Visible"/>
                        </StackPanel>
                    </Grid>

                    <!-- Input Area -->
                    <Border Grid.Row="1" BorderThickness="0" Padding="0,12,0,0" Background="Transparent">
                        <StackPanel>
                            <Border x:Name="BranchNavigatorBorder" Visibility="Collapsed" Background="{StaticResource NotebookBackgroundBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="32,0,32,8">
                                <DockPanel>
                                    <TextBlock Text="Branch:" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="BranchNavigatorCombo" SelectionChanged="BranchNavigatorCombo_SelectionChanged" Margin="8,0,0,0" MinWidth="220" Height="24"/>
                                </DockPanel>
                            </Border>

                            <Border x:Name="ToolActivityIndicatorHost"
                                    Visibility="Collapsed"
                                     HorizontalAlignment="Center"
                                     Margin="24,0,24,8"
                                    Padding="8,4"
                                       Background="#211F1D"
                                       BorderBrush="#302D2A"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Opacity="0.96">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ToolActivityIndicatorGlyph"
                                               Text="◌"
                                               FontSize="12"
                                                Foreground="#8A8279"
                                               FontFamily="Segoe UI"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <TextBlock x:Name="ToolActivityIndicatorText"
                                               Text=""
                                               FontSize="11"
                                                Foreground="#8A8279"
                                               FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Input Container -->
                            <Border x:Name="InputContainerBorder" Background="#211F1D" BorderBrush="#302D2A" BorderThickness="1" CornerRadius="24" Padding="0" Margin="24,0,24,28" Opacity="1" HorizontalAlignment="Stretch" MaxWidth="1080" MinWidth="320"
                                    AllowDrop="True" PreviewDragOver="InputContainer_PreviewDragOver" PreviewDrop="InputContainer_PreviewDrop">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="56"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" MinHeight="78" MaxHeight="180">
                                        <TextBox x:Name="InputBox" VerticalContentAlignment="Top" Padding="22,20,22,10"
                                              Background="Transparent" Foreground="#EDE8E3" BorderThickness="0" CaretBrush="#EDE8E3"
                                              FontFamily="Segoe UI" FontSize="16" PreviewKeyDown="InputBox_KeyDown" TextChanged="InputBox_TextChanged" GotFocus="InputBox_GotFocus" LostFocus="InputBox_LostFocus"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="78" MaxHeight="180"
                                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              SelectionBrush="#66B8924A" SelectionOpacity="1"/>
                                        <TextBlock Text="How can I help you today?" Foreground="#8A8279" FontFamily="Segoe UI" FontSize="15"
                                                   Margin="22,20,22,10" IsHitTestVisible="False" VerticalAlignment="Top">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=InputBox, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Attachment preview tray: chips are created in code-behind with an
                                         entrance animation whenever the user attaches files (Normal Chat only). -->
                                    <WrapPanel x:Name="AttachmentTrayPanel" Grid.Row="1" Orientation="Horizontal"
                                               Margin="18,0,18,2" Visibility="Collapsed"/>

                                    <Grid Grid.Row="2" Background="Transparent">
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                                <Button Width="34" Height="34" Margin="0,0,4,0" Click="ImportChatDocument_Click" Style="{StaticResource ChatInputIconButtonStyle}" ToolTip="Attach files (documents, spreadsheets, presentations, e-books, code, images)">
                                                    <Path Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M6,0 L8,0 L8,6 L14,6 L14,8 L8,8 L8,14 L6,14 L6,8 L0,8 L0,6 L6,6 Z"/>
                                                </Button>
                                                <Button MinWidth="96" Margin="6,0,6,0" Click="OpenPromptTemplates_Click" Style="{StaticResource ChatInputUtilityButtonStyle}" ToolTip="Prompt templates">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Path Width="13" Height="13" Margin="0,0,7,0" Stretch="Uniform"
                                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                              Data="M2,3.5 L12,3.5 M2,6.5 L12,6.5 M2,9.5 L8.5,9.5 M2,12.5 L6.5,12.5"/>
                                                        <TextBlock Text="Templates" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button MinWidth="82" Click="OpenSystemPromptEditor_Click" Style="{StaticResource ChatInputUtilityButtonStyle}" ToolTip="System prompt editor">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Path Width="13" Height="13" Margin="0,0,7,0" Stretch="Uniform"
                                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                              Data="M2,3 L12,3 M2,7 L12,7 M2,11 L12,11 M4.5,1.8 L4.5,4.2 M9,5.8 L9,8.2 M6.5,9.8 L6.5,12.2"/>
                                                        <TextBlock Text="System" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed">
                                                     <TextBlock Text="{Binding ElementName=HeaderModelName, Path=Text}" FontSize="13" Foreground="#8A8279" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                 <Border x:Name="CloudModelSelectorBorder" Height="30" Margin="0,0,8,0" Padding="2" Background="#171615" BorderBrush="#302D2A" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                                                     <Border.Resources>
                                                         <Style x:Key="ModeSelectorPillButtonStyle" TargetType="Button">
                                                             <Setter Property="Height" Value="26"/>
                                                             <Setter Property="Padding" Value="10,0,10,0"/>
                                                             <Setter Property="FontSize" Value="12"/>
                                                             <Setter Property="FontWeight" Value="Medium"/>
                                                               <Setter Property="Foreground" Value="#8A8279"/>
                                                             <Setter Property="Background" Value="Transparent"/>
                                                             <Setter Property="BorderBrush" Value="Transparent"/>
                                                             <Setter Property="BorderThickness" Value="0"/>
                                                             <Setter Property="Cursor" Value="Hand"/>
                                                             <Setter Property="Template">
                                                                 <Setter.Value>
                                                                     <ControlTemplate TargetType="Button">
                                                                         <Border x:Name="border"
                                                                                 Background="{TemplateBinding Background}"
                                                                                 BorderBrush="{TemplateBinding BorderBrush}"
                                                                                 BorderThickness="{TemplateBinding BorderThickness}"
                                                                                 CornerRadius="6">
                                                                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                                         </Border>
                                                                         <ControlTemplate.Triggers>
                                                                             <Trigger Property="IsPressed" Value="True">
                                                                                 <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                                             </Trigger>
                                                                             <Trigger Property="IsEnabled" Value="False">
                                                                                 <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                                                                             </Trigger>
                                                                         </ControlTemplate.Triggers>
                                                                     </ControlTemplate>
                                                                 </Setter.Value>
                                                             </Setter>
                                                         </Style>
                                                     </Border.Resources>
                                                     <StackPanel Orientation="Horizontal">
                                                         <Button x:Name="EidosModelButton" Content="Eidos 1" Click="EidosModelButton_Click" Style="{StaticResource ModeSelectorPillButtonStyle}" ToolTip="Use the Eidos 1 cloud model" Margin="0,0,2,0"/>
                                                         <Button x:Name="HephaModelButton" Content="Hepha 1" Click="HephaModelButton_Click" Style="{StaticResource ModeSelectorPillButtonStyle}" ToolTip="Use the Hepha 1 cloud model"/>
                                                     </StackPanel>
                                                 </Border>
                                                <Button x:Name="NormalThinkingToggleButton" Width="Auto" Height="32" Margin="0,0,8,0" Click="NormalThinkingToggle_Click"
                                                        Style="{StaticResource ChatInputToggleButtonStyle}" ToolTip="Thinking mode disabled" Visibility="Collapsed">
                                                    <TextBlock Text="Think" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                                <Button x:Name="NormalWebSearchToggleButton" Width="Auto" Height="32" Margin="0,0,8,0" Click="NormalWebSearchToggle_Click"
                                                        Style="{StaticResource ChatInputToggleButtonStyle}" ToolTip="Normal chat web search enabled">
                                                    <TextBlock Text="Web" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                                <Border x:Name="InlineLoadingIndicator" Visibility="Collapsed" Width="34" Height="34" Margin="0,0,8,0" Background="#00FFFFFF">
                                                    <Canvas x:Name="InlineLoadingSpinnerCanvas" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                        <Canvas.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Canvas.RenderTransform>
                                                         <Ellipse Canvas.Left="2" Canvas.Top="2" Width="20" Height="20" Stroke="#B8924A" StrokeThickness="2.2" Opacity="0.24"/>
                                                         <Path Data="M12,2 A10,10 0 0 1 21.2,8" Stroke="#B8924A" StrokeThickness="2.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Border>
                                                <Button x:Name="StopButton" Width="34" Height="34" Margin="0,0,8,0" Click="Stop_Click"
                                                        Style="{StaticResource ChatInputIconButtonStyle}" IsEnabled="False">
                                                    <TextBlock Text="■" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                                <Button x:Name="SendButton" Width="36" Height="36" Click="Send_Click" Style="{StaticResource ChatInputSendButtonStyle}"
                                                        ToolTip="Press Enter to send and Shift+Enter for new line">
                                                    <Path Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Data="M7,1 L12.5,6.5 L9.2,6.5 L9.2,13 L4.8,13 L4.8,6.5 L1.5,6.5 Z"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>

            <!-- WORKPLACE VIEW (hidden by default) -->
            <local:WorkplaceView x:Name="WorkplaceViewControl" Visibility="Collapsed" Opacity="0"/>

            <!-- PERSONA MEMORY VIEW -->
            <DockPanel x:Name="PersonaMemoryView" Visibility="Collapsed" Opacity="0" Background="{StaticResource NotebookBackgroundBrush}">
                <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="32,20" Background="{StaticResource NotebookSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Persona Memory" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI"/>
                        <TextBlock Text="Dump everything about yourself here — your role, preferences, habits, ongoing projects, and how you like responses. Injected as context in Normal Chat (local and cloud)." FontSize="12" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="32,20,32,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBox Text="{Binding PersonaText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" FontFamily="Segoe UI" FontSize="13" Padding="12"
                                 Background="{StaticResource NotebookSurfaceBrush}" Foreground="{StaticResource NotebookTextBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1"/>
                        <TextBlock IsHitTestVisible="False" TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="13" Padding="14,14,14,0"
                                   Foreground="{StaticResource DarkSecondaryBrush}" VerticalAlignment="Top"
                                   Visibility="{Binding IsPersonaEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Run Text="Example:&#x0a;&#x0a;I'm a software engineer, mostly working in C# and Python. I like concise, direct answers without unnecessary padding.&#x0a;&#x0a;Current project: a WPF desktop AI chat app called Axiom. I'm working on improving the inference pipeline.&#x0a;&#x0a;Preferences: always use code blocks, avoid bullet overuse, assume I know the basics."/>
                        </TextBlock>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Save" Command="{Binding SaveCommand}" Width="90" Height="34" Style="{StaticResource PremiumButtonStyle}"/>
                        <TextBlock Text="{Binding WordCountLabel}" Margin="12,8,0,0" Foreground="{StaticResource DarkSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Status}" Margin="12,8,0,0" Foreground="{StaticResource DarkSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </DockPanel>

            <!-- NEURON VIEW -->
            <DockPanel x:Name="NeuronView" Visibility="Collapsed" Opacity="0" Background="{StaticResource NotebookBackgroundBrush}">
                <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="32,20" Background="{StaticResource NotebookSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Neuron" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="NeuronSummaryText" Text="Live graph of your activity across Chat and Workplace." FontSize="12" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Grid Margin="24">
                    <Border Background="{StaticResource NotebookSurfaceBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                        <Canvas x:Name="NeuronCanvas" Background="{StaticResource NotebookBackgroundBrush}" MinHeight="460"/>
                    </Border>
                </Grid>
            </DockPanel>

            <!-- Global Settings Panel Overlay -->
            <Border x:Name="SettingsPanel" Panel.ZIndex="100" Visibility="Collapsed" Background="#CC171615" Opacity="0">
                <Grid>
                    <Border x:Name="SettingsPanelCard" BorderThickness="1" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="24,18" Margin="28,26,28,26" Background="{StaticResource NotebookSurfaceBrush}" Effect="{StaticResource SoftShadow}">
                        <Border.RenderTransform>
                            <TranslateTransform X="28"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Inference Settings" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                        <TextBlock Text="Temperature" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <Slider x:Name="TemperatureSlider" Minimum="0" Maximum="2" Value="0.7" TickFrequency="0.1" Height="6"/>
                                        <TextBlock x:Name="TemperatureValueText" Text="{Binding ElementName=TemperatureSlider, Path=Value, StringFormat={}{0:F1}}" FontSize="12" Foreground="{StaticResource PrimaryAccentBrush}" FontFamily="Segoe UI" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,24,0">
                                        <TextBlock Text="Min-P" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <Slider x:Name="TopPSlider" Minimum="0" Maximum="1" Value="0.05" TickFrequency="0.05" Height="6"/>
                                        <TextBlock x:Name="TopPValueText" Text="{Binding ElementName=TopPSlider, Path=Value, StringFormat={}{0:F2}}" FontSize="12" Foreground="{StaticResource PrimaryAccentBrush}" FontFamily="Segoe UI" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Context Length" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <Slider x:Name="CtxSlider" Minimum="512" Maximum="32768" Value="8192" TickFrequency="512" Height="6"/>
                                        <TextBlock x:Name="ContextLengthValueText" Text="{Binding ElementName=CtxSlider, Path=Value, StringFormat={}{0:F0} tokens}" FontSize="12" Foreground="{StaticResource PrimaryAccentBrush}" FontFamily="Segoe UI" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="InferenceSettingsSourceText"
                                           Text="Local mode active. These controls affect the loaded on-device model."
                                           FontSize="10"
                                           Foreground="{StaticResource DarkSecondaryBrush}"
                                           FontFamily="Segoe UI"
                                           TextWrapping="Wrap"
                                           Margin="0,-10,0,18"/>

                                <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,16,0,16">
                                    <StackPanel>
                                        <TextBlock Text="System Prompt" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <TextBox x:Name="SystemPromptBox" Background="{StaticResource NotebookBackgroundBrush}" Foreground="{StaticResource NotebookTextBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" Padding="8" FontFamily="Segoe UI" FontSize="11" AcceptsReturn="True" Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="You are a helpful AI assistant and expert software engineer. Provide clear, concise, and accurate responses. Execute tasks directly and provide final output unless explicitly asked for step-by-step guidance."/>
                                    </StackPanel>
                                </Border>

                                <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,16,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Processing Mode" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <ComboBox x:Name="ProcessingModeCombo" SelectionChanged="ProcessingModeCombo_SelectionChanged" Height="30" Width="220" Style="{StaticResource DarkComboBoxStyle}">
                                            <ComboBoxItem Content="CPU Only"/>
                                            <ComboBoxItem Content="GPU Accelerated"/>
                                        </ComboBox>
                                        <TextBlock x:Name="ProcessingRecommendationBlock" Text="Recommended: Detecting hardware..." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,16,0,16">
                                    <StackPanel>
                                         <TextBlock Text="Inference Source" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                                         <Border Height="34" Padding="2" Background="#171615" BorderBrush="#302D2A" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Left">
                                             <Border.Resources>
                                                 <Style x:Key="ModeSelectorPillButtonStyle" TargetType="Button">
                                                     <Setter Property="Height" Value="28"/>
                                                     <Setter Property="Padding" Value="14,0,14,0"/>
                                                     <Setter Property="FontSize" Value="12"/>
                                                     <Setter Property="FontWeight" Value="Medium"/>
                                                     <Setter Property="Foreground" Value="#8A8279"/>
                                                     <Setter Property="Background" Value="Transparent"/>
                                                     <Setter Property="BorderBrush" Value="Transparent"/>
                                                     <Setter Property="BorderThickness" Value="0"/>
                                                     <Setter Property="Cursor" Value="Hand"/>
                                                     <Setter Property="Template">
                                                         <Setter.Value>
                                                             <ControlTemplate TargetType="Button">
                                                                 <Border x:Name="border"
                                                                         Background="{TemplateBinding Background}"
                                                                         BorderBrush="{TemplateBinding BorderBrush}"
                                                                         BorderThickness="{TemplateBinding BorderThickness}"
                                                                         CornerRadius="6">
                                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                                 </Border>
                                                                 <ControlTemplate.Triggers>
                                                                     <Trigger Property="IsPressed" Value="True">
                                                                         <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                                     </Trigger>
                                                                     <Trigger Property="IsEnabled" Value="False">
                                                                         <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                                                                     </Trigger>
                                                                 </ControlTemplate.Triggers>
                                                             </ControlTemplate>
                                                         </Setter.Value>
                                                     </Setter>
                                                 </Style>
                                             </Border.Resources>
                                             <StackPanel Orientation="Horizontal">
                                                 <Button x:Name="LocalModeButton" Content="Local" Click="LocalModeButton_Click" Style="{StaticResource ModeSelectorPillButtonStyle}" ToolTip="Use the local on-device model" Margin="0,0,2,0"/>
                                                 <Button x:Name="CloudModeButton" Content="Cloud" Click="CloudModeButton_Click" Style="{StaticResource ModeSelectorPillButtonStyle}" ToolTip="Add an OpenRouter API key in Settings to enable cloud mode"/>
                                             </StackPanel>
                                         </Border>
                                         <TextBlock Text="Choose whether normal chat runs on your local model or the configured OpenRouter cloud model." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                     </StackPanel>
                                 </Border>

                                 <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,16,0,16">
                                     <StackPanel>
                                        <TextBlock Text="Cloud AI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                                        <TextBlock Text="OpenRouter API Key" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                        <PasswordBox x:Name="OpenRouterApiKeyPasswordBox" Height="32" Padding="8,6" Background="{StaticResource NotebookBackgroundBrush}" Foreground="{StaticResource NotebookTextBrush}" BorderBrush="{StaticResource NotebookBorderBrush}" BorderThickness="1" PasswordChanged="OpenRouterApiKeyPasswordBox_PasswordChanged"/>
                                        <TextBlock Text="Your key is stored locally. Cloud conversations are subject to the selected model/provider via OpenRouter." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                                            <Button x:Name="SaveOpenRouterKeyButton" Content="Save Key" Click="SaveOpenRouterKeyButton_Click" Height="32" MinWidth="100" Style="{StaticResource PremiumButtonStyle}" Background="#B8924A" BorderBrush="#B8924A"/>
                                            <Button x:Name="ClearOpenRouterKeyButton" Content="Clear Key" Click="ClearOpenRouterKeyButton_Click" Height="32" MinWidth="90" Margin="8,0,0,0" Style="{StaticResource SubtleButtonStyle}" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource DarkSecondaryBrush}"/>
                                            <TextBlock x:Name="OpenRouterKeyTestingText" Text="Testing" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <TextBlock x:Name="OpenRouterKeyStatusText" Text="" FontSize="10" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                        </StackPanel>
                                         <StackPanel x:Name="OpenRouterUsagePanel" Margin="0,12,0,0" Visibility="Collapsed">
                                             <TextBlock Text="Daily requests" FontSize="12" Foreground="{StaticResource DarkSecondaryBrush}" FontFamily="Segoe UI"/>
                                             <Border x:Name="OpenRouterUsageTrack" Height="8" Margin="0,6,0,0" Background="{StaticResource NotebookSurfaceBrush}" CornerRadius="4" HorizontalAlignment="Stretch" SizeChanged="OpenRouterUsageTrack_SizeChanged">
                                                 <Grid HorizontalAlignment="Left">
                                                     <Border x:Name="OpenRouterUsageFillBar" Height="8" Width="0" Background="#22C55E" CornerRadius="4" HorizontalAlignment="Left"/>
                                                 </Grid>
                                             </Border>
                                             <Grid Margin="0,6,0,0">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>
                                                 <TextBlock x:Name="OpenRouterUsageText"
                                                            Text="0 / 0 requests"
                                                            FontSize="11"
                                                            Foreground="{StaticResource DarkSecondaryBrush}"
                                                            FontFamily="Segoe UI"
                                                            VerticalAlignment="Center"
                                                            TextWrapping="Wrap"/>
                                                 <Button x:Name="RefreshOpenRouterUsageButton"
                                                         Grid.Column="1"
                                                         Width="24"
                                                         Height="24"
                                                         Margin="8,0,0,0"
                                                         Click="RefreshOpenRouterUsageButton_Click"
                                                         Style="{StaticResource ChatInputIconButtonStyle}"
                                                         ToolTip="Refresh daily request usage">
                                                     <TextBlock Text="↻" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                 </Button>
                                             </Grid>
                                         </StackPanel>
                                         <TextBlock Text="Active cloud model" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,14,0,8"/>
                                         <TextBlock x:Name="OpenRouterDetectedModelText" Text="Eidos 1" FontSize="11" Foreground="{StaticResource NotebookTextBrush}" TextWrapping="Wrap"/>
                                         <TextBlock x:Name="OpenRouterDetectedModelIdText" Text="General reasoning profile tuned for Axiom's tool pipeline." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,16,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Workplace notifications" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="CouncilCompletionToastToggle"
                                                  Content="Notify me when a council run finishes while Axiom is in the background"
                                                  IsChecked="True"
                                                  Checked="CouncilCompletionToastToggle_Changed"
                                                  Unchecked="CouncilCompletionToastToggle_Changed"
                                                  Foreground="{StaticResource NotebookTextBrush}"
                                                  FontSize="11"/>
                                        <TextBlock Text="Clicking the Windows notification restores and focuses Axiom. No notification is shown while this window is active."
                                                   FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,16,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Smart Context Compaction" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotebookTextBrush}" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="SmartCompactionToggle" Content="Enable automatic context optimization" IsChecked="True" Checked="SmartCompactionToggle_Changed" Unchecked="SmartCompactionToggle_Changed" Foreground="{StaticResource NotebookTextBrush}" FontSize="11"/>
                                        <TextBlock Text="Automatically compresses low-priority messages when context usage reaches 80% of the model's reliability ceiling." FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{StaticResource NotebookBorderBrush}" Padding="0,12,0,0" Margin="0,12,0,0">
                                <Grid>
                                    <TextBlock x:Name="AppVersionLabel" Text="Version 1.5.0" FontSize="10" Foreground="{StaticResource DarkSecondaryBrush}" FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <Button Content="Close Settings" Click="Settings_Click" Height="32" Style="{StaticResource SubtleButtonStyle}" Foreground="{StaticResource DarkSecondaryBrush}" FontSize="11" HorizontalAlignment="Right" Width="120"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Update notification banner: shown on startup when a newer GitHub release exists.
             Slides down + fades in; click downloads and runs the installer; ✕ dismisses. -->
        <Border x:Name="UpdateBannerBorder" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                Panel.ZIndex="9000" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,56,0,0" Visibility="Collapsed" Opacity="0"
                Background="#26231F" BorderBrush="#B8924A" BorderThickness="1" CornerRadius="12"
                Padding="16,10" Cursor="Hand"
                MouseLeftButtonUp="UpdateBanner_Click">
            <Border.RenderTransform>
                <TranslateTransform Y="-24"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.45" Color="#000000"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⬆" FontSize="15" Foreground="#B8924A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateBannerTitleText" Text="Update available" FontSize="12" FontWeight="SemiBold" Foreground="#EDE8E3" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="UpdateBannerDetailText" Text="" FontSize="11" Foreground="#8A8279" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="UpdateBannerCloseButton" Content="✕" Click="UpdateBannerClose_Click" Width="22" Height="22" Margin="14,0,0,0"
                        Background="Transparent" BorderBrush="Transparent" Foreground="#8A8279" FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                        ToolTip="Dismiss"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

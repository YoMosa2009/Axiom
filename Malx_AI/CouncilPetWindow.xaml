<Window x:Class="Malx_AI.CouncilPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Axiom Bit"
        Width="260"
        Height="174"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Border x:Name="PetRoot"
            Background="#E6171615"
            BorderBrush="#66B8924A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="10"
            MouseLeftButtonDown="PetRoot_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Canvas Width="104" Height="118" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.45"/>
                </Canvas.Effect>

                <!-- antenna -->
                <Rectangle Canvas.Left="42" Canvas.Top="0" Width="14" Height="14" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="28" Canvas.Top="14" Width="14" Height="14" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="56" Canvas.Top="14" Width="14" Height="14" Fill="#FFC83D"/>

                <!-- head shell -->
                <Rectangle Canvas.Left="20" Canvas.Top="28" Width="64" Height="12" Fill="#25282E"/>
                <Rectangle Canvas.Left="8" Canvas.Top="40" Width="88" Height="14" Fill="#25282E"/>
                <Rectangle Canvas.Left="0" Canvas.Top="54" Width="104" Height="28" Fill="#25282E"/>
                <Rectangle Canvas.Left="8" Canvas.Top="82" Width="88" Height="14" Fill="#25282E"/>
                <Rectangle Canvas.Left="20" Canvas.Top="96" Width="64" Height="10" Fill="#25282E"/>

                <!-- ears -->
                <Rectangle Canvas.Left="0" Canvas.Top="62" Width="12" Height="28" Fill="#1B1D22"/>
                <Rectangle Canvas.Left="92" Canvas.Top="62" Width="12" Height="28" Fill="#1B1D22"/>
                <Rectangle Canvas.Left="0" Canvas.Top="68" Width="8" Height="18" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="96" Canvas.Top="68" Width="8" Height="18" Fill="#FFC83D"/>

                <!-- face plate -->
                <Rectangle Canvas.Left="20" Canvas.Top="48" Width="64" Height="44" Fill="#090B0C"/>
                <Rectangle Canvas.Left="82" Canvas.Top="52" Width="8" Height="8" Fill="#F1F0E6"/>
                <Rectangle Canvas.Left="90" Canvas.Top="60" Width="8" Height="8" Fill="#F1F0E6"/>

                <!-- pixel prompt face -->
                <Rectangle Canvas.Left="32" Canvas.Top="62" Width="10" Height="8" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="40" Canvas.Top="68" Width="10" Height="8" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="50" Canvas.Top="74" Width="10" Height="8" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="40" Canvas.Top="80" Width="10" Height="8" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="32" Canvas.Top="86" Width="10" Height="8" Fill="#FFC83D"/>
                <Rectangle Canvas.Left="62" Canvas.Top="84" Width="28" Height="6" Fill="#FFC83D"/>

                <!-- body -->
                <Rectangle Canvas.Left="30" Canvas.Top="104" Width="44" Height="10" Fill="#16191D"/>
                <Rectangle Canvas.Left="36" Canvas.Top="106" Width="32" Height="8" Fill="#FFC83D"/>
            </Canvas>

            <Border Grid.Column="1"
                    Background="#F0212020"
                    BorderBrush="#40302D2A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10"
                    VerticalAlignment="Center">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="RoleText"
                                   Text="Council Bit"
                                   Foreground="#EDE8E3"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   DockPanel.Dock="Left"/>
                        <Button Content="×"
                                Width="22"
                                Height="22"
                                DockPanel.Dock="Right"
                                Click="CloseButton_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#8A8279"
                                Padding="0"
                                ToolTip="Hide Bit"/>
                    </DockPanel>
                    <TextBlock x:Name="MessageText"
                               Text="Idle and ready."
                               Foreground="#CFC7BC"
                               FontSize="12"
                               TextWrapping="Wrap"
                               LineHeight="17"/>
                    <TextBlock Text="Drag me anywhere"
                               Foreground="#8A8279"
                               FontSize="9"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
